

{% liquid
  assign product_resource = closest.product
  if request.visual_preview_mode and product_resource == blank
    assign product_resource = collections.all.products.first
  endif
-%}

{% unless product_resource == blank %}
  <div
    class="lux-variant-wrapper"
    data-edge-style="{{ section.settings.edge_style }}"
    data-animate="{{ section.settings.enable_animation }}"
    data-effect="{{ section.settings.effect_style }}"
    style="
      padding-block-start: {{ section.settings.padding-block-start }}px;
      padding-block-end: {{ section.settings.padding-block-end }}px;
      padding-inline-start: {{ section.settings.padding-inline-start }}px;
      padding-inline-end: {{ section.settings.padding-inline-end }}px;
      text-align: {{ section.settings.alignment }};
    "
  >
    {% render 'variant-main-picker', product_resource: product_resource %}
  </div>
{% endunless %}


{% schema %}
{
  "name": "t:names.product_variant_picker",
  "tag": null,
  "settings": [
    {
      "type": "paragraph",
      "content": "Luxury variant selector styling"
    },
    {
      "type": "select",
      "id": "edge_style",
      "label": "Button edge style",
      "options": [
        { "value": "sharp", "label": "Sharp" },
        { "value": "round", "label": "Rounded" },
        { "value": "pill", "label": "Pill" }
      ],
      "default": "sharp"
    },
    {
      "type": "select",
      "id": "effect_style",
      "label": "Selection effect",
      "options": [
        { "value": "invert", "label": "Invert (Black ↔ White)" },
        { "value": "glow", "label": "Glow" },
        { "value": "none", "label": "None" }
      ],
      "default": "invert"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable button animation",
      "default": true
    },
    {
      "type": "text_alignment",
      "id": "alignment",
      "label": "Alignment",
      "default": "left"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Luxury Variant Picker",
      "category": "Product"
    }
  ]
}
{% endschema %}
